# API GATEWAY — Variables de Entorno
# Copia este archivo a .env y completa los valores
# NUNCA subas .env a GitHub

# Puerto del gateway
PORT=3000

# Ambiente
NODE_ENV=development

# URL de Supabase
SUPABASE_URL=https://xtbzwxwrlvtsdbppdgxe.supabase.co
SUPABASE_ANON_KEY=tu_anon_key_aqui

# Secreto para verificar JWTs de Supabase
# Encuentra este valor en: Supabase Dashboard > Settings > API > JWT Secret
JWT_SECRET=tu_jwt_secret_de_supabase_aqui

# Clave interna entre servicios (generar con: openssl rand -hex 32)
INTERNAL_API_KEY=genera_una_clave_aleatoria_larga_aqui

# URLs de los microservicios (en producción son las URLs de Vercel)
AUTH_SERVICE_URL=http://localhost:3001
COURSE_SERVICE_URL=http://localhost:3002
QUIZ_SERVICE_URL=http://localhost:3003
USER_SERVICE_URL=http://localhost:3004

# Nivel de logging
LOG_LEVEL=info
